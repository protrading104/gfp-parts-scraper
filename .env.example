# Google Sheets integration
# 1. Create service account: https://console.cloud.google.com
# 2. Enable: Google Sheets API + Google Drive API
# 3. Download JSON key → put path here
GOOGLE_SA_PATH=credentials/service_account.json

# Optional: use existing spreadsheet (leave blank to auto-create "GFP_Parts_Scrape")
GOOGLE_SPREADSHEET_ID=
